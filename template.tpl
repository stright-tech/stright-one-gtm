const injectScript = require("injectScript");
const encodeUriComponent = require("encodeUriComponent");
const logToConsole = require("logToConsole");
const setDefaultConsentState = require("setDefaultConsentState");
const updateConsentState = require("updateConsentState");
const getCookieValues = require("getCookieValues");
const JSON = require("JSON");
const createArgumentsQueue = require("createArgumentsQueue");

var WAIT_FOR_UPDATE_MS = 500;

var CATEGORY_TO_KEYS = {
  targetingCategory: ["ad_storage", "ad_user_data", "ad_personalization"],
  performanceCategory: ["analytics_storage"],
  functionalCategory: ["functionality_storage", "personalization_storage"],
  securityCategory: ["security_storage"],
};

var REGION_FIELD_TO_KEYS = {
  performanceRegionCategory: ["analytics_storage"],
  functionalRegionCategory: ["functionality_storage", "personalization_storage"],
  targetingRegionCategory: ["ad_storage", "ad_user_data", "ad_personalization"],
  securityRegionCategory: ["security_storage"],
};

var GCM_KEYS = [
  "ad_storage",
  "ad_user_data",
  "ad_personalization",
  "analytics_storage",
  "functionality_storage",
  "personalization_storage",
  "security_storage",
];

// GTM テンプレート設定をまとめて保持
var config = {
  dataSiteId: data.dataSiteId,
  srcUrl: data.srcUrl,
  googleConsentMode: data.googleConsentMode,
  gcmConfigTable: data.googleConsentModeConfiguration,
  regionOverridesTable: data.regionConsentOverrides,
  siteDomainTable: data.siteDomain,
};

// setting 用スクリプト URL とキャッシュキーを組み立てる
function buildSettingUrl(cfg) {
  var baseUrl = "https://" + cfg.srcUrl + "/js/cookie_consent_setting.js";
  var scriptSrc = baseUrl + "?banner_type=banner";

  if (cfg.dataSiteId) {
    scriptSrc += "&dsi=" + encodeUriComponent(cfg.dataSiteId);
  }
  return { scriptSrc: scriptSrc, cacheToken: baseUrl };
}

// テンプレート上の consent モデル文字列を GCM 値に正規化
function mapConsentModelToValue(consentModel) {
  if (!consentModel) return null;

  var normalized = ("" + consentModel).toLowerCase();
  if (normalized === "optin") {
    return "denied";
  }
  if (normalized === "optout" || normalized === "opout") {
    return "granted";
  }
  if (normalized === "alwaysactive") {
    return "granted";
  }
  if (normalized === "alwaysnotactive") {
    return "denied";
  }

  return null;
}

// カテゴリ名から対応する GCM キー配列を取得
function mapCategoryToKeys(category) {
  return CATEGORY_TO_KEYS[category] || [];
}

// AlwaysActive/AlwaysNotActive のキーを強制値としてまとめる
function buildForcedConsentOverrides(configTable) {
  var overrides = {};

  if (!configTable || !configTable.length) {
    return overrides;
  }

  for (var i = 0; i < configTable.length; i++) {
    var row = configTable[i];
    if (!row || !row.consentModel) continue;

    var normalized = ("" + row.consentModel).toLowerCase();
    if (normalized !== "alwaysactive" && normalized !== "alwaysnotactive") {
      continue;
    }

    var consentValue = mapConsentModelToValue(row.consentModel);
    var keys = mapCategoryToKeys(row.category);

    if (!consentValue || !keys.length) continue;

    for (var k = 0; k < keys.length; k++) {
      overrides[keys[k]] = consentValue;
    }
  }

  return overrides;
}

// テンプレートのデフォルト同意テーブルから GCM デフォルト状態を構築
function buildDefaultConsentStateFromTable(configTable) {
  var defaultState = {
    wait_for_update: WAIT_FOR_UPDATE_MS,
  };

  if (!configTable || !configTable.length) {
    return defaultState;
  }

  for (var i = 0; i < configTable.length; i++) {
    var row = configTable[i];
    if (!row) continue;

    var keys = mapCategoryToKeys(row.category);

    var consentValue = mapConsentModelToValue(row.consentModel);

    if (!keys.length || !consentValue) continue;

    for (var k = 0; k < keys.length; k++) {
      defaultState[keys[k]] = consentValue;
    }
  }

  return defaultState;
}

// CSV 形式のリージョンコードを配列に変換
function parseRegionCodes(regionCodeString) {
  if (!regionCodeString) return [];

  var parts = regionCodeString.split(",");
  var out = [];

  for (var i = 0; i < parts.length; i++) {
    var code = parts[i];
    if (!code) continue;

    var trimmed = ("" + code).trim();
    if (!trimmed) continue;

    out.push(trimmed.toUpperCase());
  }
  return out;
}

// リージョン設定の On/Off/default を GCM 値に変換
function mapRegionChoiceToValue(choice) {
  if (choice === "On") {
    return "granted";
  } else if (choice === "Off") {
    return "denied";
  }
  return null;
}

// リージョン用フィールド名から GCM キー配列を取得
function mapRegionFieldToKeys(fieldName) {
  return REGION_FIELD_TO_KEYS[fieldName] || [];
}

// リージョン別のデフォルト同意設定を反映
function applyRegionalDefaultConsent(regionOverridesTable) {
  if (!regionOverridesTable || !regionOverridesTable.length) {
    return;
  }

  for (var i = 0; i < regionOverridesTable.length; i++) {
    var row = regionOverridesTable[i];
    if (!row) continue;

    var regions = parseRegionCodes(row.regionCode);
    if (!regions.length) {
      continue;
    }

    var regionalState = {
      wait_for_update: WAIT_FOR_UPDATE_MS,
      region: regions,
    };

    var hasOverride = false;

    var fields = [
      "performanceRegionCategory",
      "functionalRegionCategory",
      "targetingRegionCategory",
      "securityRegionCategory",
    ];

    for (var f = 0; f < fields.length; f++) {
      var fieldName = fields[f];
      var choice = row[fieldName];

      var consentValue = mapRegionChoiceToValue(choice);
      if (!consentValue) {
        continue;
      }

      var keys = mapRegionFieldToKeys(fieldName);
      if (!keys.length) continue;

      for (var k = 0; k < keys.length; k++) {
        regionalState[keys[k]] = consentValue;
        hasOverride = true;
      }
    }

    if (hasOverride) {
      logToConsole("Set regional default consent:", regionalState);
      setDefaultConsentState(regionalState);
    }
  }
}

// JSON っぽい文字列か簡易チェック
function looksLikeJson(str) {
  if (!str) return false;

  var first = str.charAt(0);
  if (first !== "{" && first !== "[") {
    return false;
  }

  return true;
}

// cookie_consent_gcm_data から指定 cmd の GCM キー配列を取得
function getGcmTypesFromCookie(cmd) {
  var values = getCookieValues("cookie_consent_gcm_data");
  if (!values || values.length === 0) return null;

  var raw = values[0];
  if (!raw) return null;
  logToConsole("cookie_consent_gcm_data raw:", raw);

  if (!looksLikeJson(raw)) {
    logToConsole("cookie_consent_gcm_data is not JSON-like");
    return null;
  }

  var cData = JSON.parse(raw);
  if (!cData || cData.cmd !== cmd) {
    return null;
  }

  if (!cData.gGcType || !cData.gGcType.length) {
    return null;
  }

  logToConsole("cookie_consent_gcm_data gGcType:", cData.gGcType);
  return cData.gGcType;
}

// すべて denied の初期状態オブジェクトを生成
function buildAllDeniedState() {
  var state = {};

  for (var i = 0; i < GCM_KEYS.length; i++) {
    state[GCM_KEYS[i]] = "denied";
  }

  return state;
}

// 配列に含まれるキーのみ granted の update オブジェクトを生成
function buildGrantedOnlyState(val, forcedOverrides) {
  var result = {};
  var hasGranted = false;

  // 強制値があるキーは Cookie による上書きをさせない
  var forced = forcedOverrides || {};

  for (var i = 0; i < val.length; i++) {
    var key = val[i];
    if (key && typeof key === "string" && !forced.hasOwnProperty(key)) {
      result[key] = "granted";
      hasGranted = true;
    }
  }

  if (!hasGranted) {
    return null;
  }
  return result;
}

// 既存状態に強制値を適用して返す
function applyForcedToState(state, forcedOverrides) {
  if (!forcedOverrides) return state;

  for (var key in forcedOverrides) {
    if (forcedOverrides.hasOwnProperty(key)) {
      state[key] = forcedOverrides[key];
    }
  }
  return state;
}

// 指定スクリプトを読み込み、成功/失敗をコールバックで通知
function loadScript(urls, onDone) {
  logToConsole("Loading script:", urls.scriptSrc);

  injectScript(
    urls.scriptSrc,
    function () {
      logToConsole("Script loaded:", urls.scriptSrc);
      onDone(true);
    },
    function () {
      logToConsole("Script load failed:", urls.scriptSrc);
      onDone(false);
    },
    urls.cacheToken
  );
}

// メイン処理：デフォルト同意設定とスクリプトロードの実行
function run() {

  var gtag = createArgumentsQueue("gtag", "dataLayer");

  // ① GCM デフォルト同意を設定（Cookie があればそれを優先）
  if (config.googleConsentMode === true) {
    // AlwaysActive/AlwaysNotActive はキー単位で強制し、それ以外は Cookie を参照
    var forcedOverrides = buildForcedConsentOverrides(config.gcmConfigTable);
    var cookieVal = getGcmTypesFromCookie(config.siteDomainTable);

    if (cookieVal) {
      // Cookie がある場合は全否定 → 強制値を反映 → Cookie のキーだけ許可
      var allDenied = applyForcedToState(buildAllDeniedState(), forcedOverrides);
      setDefaultConsentState(allDenied);
      logToConsole("Cookie found. Set default consent state (with forced overrides):", allDenied);

      var grantedOnly = buildGrantedOnlyState(cookieVal, forcedOverrides);
      if (grantedOnly) {
        updateConsentState(grantedOnly);
        logToConsole("Then updated consent state from cookie (granted only):", grantedOnly);
      } else {
        logToConsole("Consent cookie had no keys to grant. Keep all denied default.");
      }
    } else {
      // Cookie が無い場合はテーブルからデフォルトを構成（強制値はここに含まれる）
      var defaultConsentState = buildDefaultConsentStateFromTable(config.gcmConfigTable);

      logToConsole("Set default consent state:", defaultConsentState);
      setDefaultConsentState(defaultConsentState);

      applyRegionalDefaultConsent(config.regionOverridesTable);
      logToConsole("Applied regional default consent overrides.");
    }
  } else {
    logToConsole("googleConsentMode is false. Skip setting default consent state.");
  }

  // ② cookie_consent_setting.js をロード
  var settingUrls = buildSettingUrl(config);
  loadScript(settingUrls, function (okSetting) {
    if (!okSetting) {
      logToConsole("cookie_consent_setting.js load failed.");
      data.gtmOnFailure();
      return;
    }
    data.gtmOnSuccess();
  });
}

// エントリーポイント
run();


